# ======================
# Java build artifacts
# ======================
bin/
target/
out/
*.class

# ======================
# Eclipse project files
# ======================
.classpath
.project
.settings/
.metadata/

# ======================
# VS Code project files
# ======================
.vscode/
!.vscode/settings.json   # keep settings.json (classpath references)

# ======================
# OS-generated files
# ======================
.DS_Store
Thumbs.db
desktop.ini

# ======================
# Logs and temp
# ======================
*.log
*.tmp

# ======================
# Archives
# ======================
*.zip
*.tar.gz

# ======================
# JARs
# ======================
# Ignore all jars by default
*.jar

# Keep jars inside lib (any depth)
!lib/**/*.jar
!lib/*.jar
